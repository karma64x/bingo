<body>
    <div class="main-container">
        <h1>🍽️ BINGO 3D/4D</h1>
        <div class="subtitle">Impresión de alimentos para hospitales</div>

        <div class="tabs">
            <button class="tab active" data-tab="player">🎲 BINGO (Jugador)</button>
            <button class="tab" data-tab="checker">📋 Verificador</button>
        </div>

        <!-- Panel del jugador -->
        <div class="panel active" id="playerPanel">
            <div class="counter">Marcadas: <span id="markedCount">0</span> / 15</div>
            <div class="bingo-board" id="board"></div>
            <div class="bingo-message" id="bingoMsg">🎉 ¡BINGO! ¡Cartón completo! 🎉</div>
            <div class="button-group">
                <button id="newCardBtn">🔄 NUEVO CARTÓN</button>
                <button id="resetMarksBtn">↩️ REINICIAR MARCAS</button>
            </div>
            <div class="warning">Tocá las palabras al escucharlas durante la exposición.</div>
        </div>

        <!-- Panel del verificador (compañero) -->
        <div class="panel" id="checkerPanel">
            <div class="checker-counter">Palabras dichas: <span id="checkerCount">0</span> / 70</div>
            <div class="checker-list" id="checkerList"></div>
            <div style="margin-top: 15px;">
                <button id="resetCheckerBtn">🗑️ REINICIAR LISTA</button>
            </div>
            <div class="warning">Tocá cada palabra cuando la pronuncies para tacharla.</div>
        </div>
    </div>

    <div class="confetti-container" id="confettiContainer"></div>

    <script>
        (function() {
            // ----------------------------------------------
            // LISTA DE PALABRAS EN ORDEN CRONOLÓGICO
            // ----------------------------------------------
            const palabrasCronologicas = [
                "potencias", "impresión", "3D", "4D", "alimentos", "Japón", "nutrición", "sushi",
                "cartuchos", "ingredientes", "vegetales", "algas", "enzimas", "fibras", "nutrientes",
                "sabores", "diseño", "salud", "adultos", "alimentación", "texturas", "mercado",
                "precisión", "crecimiento", "Estados Unidos", "carne", "liderazgo", "cocción",
                "láser", "pollo", "salmón", "humedad", "hornos", "hardware", "impresora",
                "extrusión", "Alemania", "plantas", "forma", "color", "estímulos", "ingeniería",
                "seguridad", "automatización", "limpieza", "Países Bajos", "azúcar", "geometrías",
                "encapsulación", "cocinas", "proteínas", "México", "aplicaciones", "hospitalidad",
                "gubernamental", "restaurantero", "Brasil", "software", "simulación", "segmentación",
                "hospitales", "tomografía", "modelos", "planificación", "quirúrgica", "capacitación",
                "entrenamiento", "residentes", "cirugías", "insumos"
            ];

            // Configuración del cartón
            const FILAS = 3;
            const COLUMNAS = 9;
            const PALABRAS_POR_FILA = 5;

            // ---------- ESTADO DEL JUGADOR ----------
            let currentBoard = [];
            let marked = [];
            let boardId = "";

            // ---------- ESTADO DEL VERIFICADOR ----------
            let palabrasDichas = new Array(palabrasCronologicas.length).fill(false);

            // Referencias DOM generales
            const tabs = document.querySelectorAll('.tab');
            const panels = document.querySelectorAll('.panel');
            const playerPanel = document.getElementById('playerPanel');
            const checkerPanel = document.getElementById('checkerPanel');
            const boardEl = document.getElementById('board');
            const markedCountEl = document.getElementById('markedCount');
            const bingoMsgEl = document.getElementById('bingoMsg');
            const newCardBtn = document.getElementById('newCardBtn');
            const resetMarksBtn = document.getElementById('resetMarksBtn');
            const confettiContainer = document.getElementById('confettiContainer');
            const checkerListEl = document.getElementById('checkerList');
            const checkerCountEl = document.getElementById('checkerCount');
            const resetCheckerBtn = document.getElementById('resetCheckerBtn');

            // ---------- CAMBIO DE PESTAÑAS ----------
            tabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    const target = tab.dataset.tab;
                    // Actualizar pestañas activas
                    tabs.forEach(t => t.classList.remove('active'));
                    tab.classList.add('active');
                    // Mostrar panel correspondiente
                    panels.forEach(panel => panel.classList.remove('active'));
                    document.getElementById(target === 'player' ? 'playerPanel' : 'checkerPanel').classList.add('active');
                    
                    if (target === 'checker') {
                        renderChecker();
                    }
                });
            });

            // ---------- GENERACIÓN DE CARTÓN ----------
            function generarCarton() {
                const carton = new Array(FILAS * COLUMNAS).fill("");
                // Barajar copia de palabras
                const palabrasDisponibles = [...palabrasCronologicas];
                for (let i = palabrasDisponibles.length - 1; i > 0; i--) {
                    const j = Math.floor(Math.random() * (i + 1));
                    [palabrasDisponibles[i], palabrasDisponibles[j]] = [palabrasDisponibles[j], palabrasDisponibles[i]];
                }

                let idxPalabra = 0;
                for (let fila = 0; fila < FILAS; fila++) {
                    const posiciones = [];
                    while (posiciones.length < PALABRAS_POR_FILA) {
                        const col = Math.floor(Math.random() * COLUMNAS);
                        if (!posiciones.includes(col)) posiciones.push(col);
                    }
                    posiciones.sort((a, b) => a - b);
                    for (let col of posiciones) {
                        const index = fila * COLUMNAS + col;
                        carton[index] = palabrasDisponibles[idxPalabra];
                        idxPalabra++;
                    }
                }
                return carton;
            }

            function generarBoardId(board) {
                return board.join('|');
            }

            // ---------- PERSISTENCIA DEL JUGADOR ----------
            function guardarEstadoJugador() {
                const estado = {
                    board: currentBoard,
                    marked: marked,
                    id: boardId
                };
                localStorage.setItem('bingo3d4d_jugador', JSON.stringify(estado));
            }

            function cargarEstadoJugador() {
                const data = localStorage.getItem('bingo3d4d_jugador');
                if (data) {
                    try {
                        const estado = JSON.parse(data);
                        if (estado.board && Array.isArray(estado.board) && estado.board.length === FILAS * COLUMNAS &&
                            estado.marked && Array.isArray(estado.marked) && estado.marked.length === FILAS * COLUMNAS) {
                            currentBoard = estado.board;
                            marked = estado.marked;
                            boardId = estado.id || generarBoardId(currentBoard);
                            return true;
                        }
                    } catch (e) {}
                }
                return false;
            }

            function renderBoard() {
                boardEl.innerHTML = '';
                for (let i = 0; i < currentBoard.length; i++) {
                    const cell = document.createElement('div');
                    cell.className = 'cell';
                    if (currentBoard[i] === '') {
                        cell.classList.add('empty');
                        cell.textContent = '';
                    } else {
                        cell.textContent = currentBoard[i];
                        if (marked[i]) {
                            cell.classList.add('marked');
                        }
                        cell.addEventListener('click', () => toggleMark(i));
                    }
                    boardEl.appendChild(cell);
                }
                actualizarContador();
            }

            function toggleMark(index) {
                if (currentBoard[index] === '') return;
                marked[index] = !marked[index];
                const cells = boardEl.children;
                if (cells[index]) {
                    if (marked[index]) {
                        cells[index].classList.add('marked');
                    } else {
                        cells[index].classList.remove('marked');
                    }
                }
                actualizarContador();
                guardarEstadoJugador();
                verificarBingo();
            }

            function actualizarContador() {
                const marcadas = marked.filter((m, i) => m && currentBoard[i] !== '').length;
                markedCountEl.textContent = marcadas;
            }

            function verificarBingo() {
                const totalPalabras = FILAS * PALABRAS_POR_FILA; // 15
                const marcadas = marked.filter((m, i) => m && currentBoard[i] !== '').length;
                if (marcadas === totalPalabras) {
                    mostrarBingo();
                } else {
                    bingoMsgEl.style.display = 'none';
                }
            }

            function mostrarBingo() {
                bingoMsgEl.style.display = 'block';
                lanzarConfeti();
                setTimeout(() => {
                    bingoMsgEl.style.display = 'none';
                }, 8000);
            }

            function lanzarConfeti() {
                for (let i = 0; i < 80; i++) {
                    const piece = document.createElement('div');
                    piece.className = 'confetti-piece';
                    piece.style.left = Math.random() * 100 + '%';
                    piece.style.backgroundColor = `hsl(${Math.random() * 360}, 100%, 60%)`;
                    piece.style.animationDuration = (Math.random() * 2 + 2) + 's';
                    piece.style.animationDelay = Math.random() * 0.5 + 's';
                    piece.style.width = (Math.random() * 8 + 6) + 'px';
                    piece.style.height = (Math.random() * 8 + 6) + 'px';
                    confettiContainer.appendChild(piece);
                    piece.addEventListener('animationend', () => {
                        piece.remove();
                    });
                }
            }

            function resetMarcasJugador() {
                marked = new Array(FILAS * COLUMNAS).fill(false);
                renderBoard();
                guardarEstadoJugador();
                bingoMsgEl.style.display = 'none';
            }

            function nuevoCarton() {
                currentBoard = generarCarton();
                marked = new Array(FILAS * COLUMNAS).fill(false);
                boardId = generarBoardId(currentBoard);
                renderBoard();
                guardarEstadoJugador();
                bingoMsgEl.style.display = 'none';
                confettiContainer.innerHTML = '';
            }

            // ---------- VERIFICADOR ----------
            function cargarEstadoVerificador() {
                const data = localStorage.getItem('bingo3d4d_checker');
                if (data) {
                    try {
                        const arr = JSON.parse(data);
                        if (Array.isArray(arr) && arr.length === palabrasCronologicas.length) {
                            palabrasDichas = arr;
                            return true;
                        }
                    } catch (e) {}
                }
                return false;
            }

            function guardarEstadoVerificador() {
                localStorage.setItem('bingo3d4d_checker', JSON.stringify(palabrasDichas));
            }

            function renderChecker() {
                checkerListEl.innerHTML = '';
                palabrasCronologicas.forEach((palabra, index) => {
                    const chip = document.createElement('span');
                    chip.className = 'word-chip';
                    if (palabrasDichas[index]) {
                        chip.classList.add('checked');
                    }
                    chip.textContent = palabra;
                    chip.addEventListener('click', () => {
                        palabrasDichas[index] = !palabrasDichas[index];
                        if (palabrasDichas[index]) {
                            chip.classList.add('checked');
                        } else {
                            chip.classList.remove('checked');
                        }
                        actualizarContadorChecker();
                        guardarEstadoVerificador();
                    });
                    checkerListEl.appendChild(chip);
                });
                actualizarContadorChecker();
            }

            function actualizarContadorChecker() {
                const count = palabrasDichas.filter(v => v).length;
                checkerCountEl.textContent = count;
            }

            function resetChecker() {
                palabrasDichas = new Array(palabrasCronologicas.length).fill(false);
                renderChecker();
                guardarEstadoVerificador();
            }

            // ---------- INICIALIZACIÓN ----------
            function initJugador() {
                const estadoPrevio = cargarEstadoJugador();
                if (!estadoPrevio) {
                    currentBoard = generarCarton();
                    marked = new Array(FILAS * COLUMNAS).fill(false);
                    boardId = generarBoardId(currentBoard);
                    guardarEstadoJugador();
                }
                renderBoard();
                verificarBingo();
            }

            function initVerificador() {
                if (!cargarEstadoVerificador()) {
                    palabrasDichas = new Array(palabrasCronologicas.length).fill(false);
                    guardarEstadoVerificador();
                }
                // Se renderiza al cambiar de pestaña
            }

            // Eventos de botones
            newCardBtn.addEventListener('click', nuevoCarton);
            resetMarksBtn.addEventListener('click', resetMarcasJugador);
            resetCheckerBtn.addEventListener('click', resetChecker);

            // Inicialización general
            initJugador();
            initVerificador();
            // Mostrar el verificador si se activa la pestaña (por si es la primera carga)
            // El renderizado del verificador se hará cuando se active la pestaña

        })();
    </script>
</body>
</html>
